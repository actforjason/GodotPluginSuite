; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="godot-plugin-suite"
run/main_scene="uid://b8kmqkbt6w0po"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/extend_to_title=true
window/ios/hide_status_bar=false

[dotnet]

project/assembly_name="godot-plugin-suite"

[editor_plugins]

enabled=PackedStringArray("res://addons/kenyoni/plugin_reloader/plugin.cfg", "res://addons/plugin_devtools/plugin.cfg", "res://addons/utility_plugin_suite/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

